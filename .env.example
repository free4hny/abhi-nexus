# Environment Configuration Template
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to version control

# OpenAI API Key
OPENAI_API_KEY=sk-proj-your-api-key-here

# JWT Secret for token signing (use a strong random string)
JWT_SECRET_KEY=your-secure-random-secret-key-here

# Admin and Viewer Passwords (use strong passwords)
ADMIN_PASSWORD=your-strong-admin-password-here
VIEWER_PASSWORD=your-strong-viewer-password-here

# Email Configuration
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password-here
